\n    width: max-content;\n    padding: 10px 20px;\n    line-height: 1;\n  @media(max-width: 768px){\n    font-size: 15px;\n    padding: 8px 16px;\n  }\n}\n\n.brand-card p {\n  font-size: 16px;\n  line-height: 1.6;\n  color: white;\n\n  @media(max-width: 768px){\n    font-size: 12px;\n  }\n}\n\n/* ── Splide (mobile) overrides ── */\n.splide__slide {\n  display: flex;\n  justify-content: center;\n}\n\n.splide__slide .brand-card {\n  width: 100%;\n  max-width: 400px;\n  transition: opacity 0.4s ease, border-color 0.4s ease;\n}\n\n\n\n.splide__slide.is-active .brand-card h3,\n.splide__slide.is-active .brand-card p {\n  display: inline-block;\n  transition: transform 0.4s ease;\n  transform-origin: left center;\n}\n\n\n\n.splide__slide:not(.is-active) .brand-card h3,\n.splide__slide:not(.is-active) .brand-card p {\n  transform: scale(1);\n  transition: transform 0.4s ease;\n}\n\n/* Hide arrows & dots */\n.splide__pagination,\n.splide__arrow {\n  display: none;\n}\n</style>\n\n<section class=\"brand-section\">\n  <div class=\"brand-inner\">\n    <div class=\"brand-tag\">BRAND PHILOSOPHY</div>\n    <h2 class=\"brand-title\">Why \"Charmacy Milano\"?</h2>\n\n    <!-- DESKTOP: static 3-column layout -->\n    <div class=\"brand-desktop-grid\">\n      <div class=\"brand-card\">\n        <h3>Charmacy</h3>\n        <p>The fusion of <strong>Charm</strong> and <strong>Pharmacy</strong> represents our unique philosophy where <strong>beauty meets science</strong> in perfect harmony.</p>\n      </div>\n      <div class=\"brand-card\">\n        <h3>Milano</h3>\n        <p>Embodies Italian sophistication, artistry, and the timeless elegance that defines global beauty excellence.</p>\n      </div>\n      <div class=\"brand-card\">\n        <h3>Our Vision</h3>\n        <p>Performance-first, clean formulations rooted in global aesthetics, delivering results without compromise.</p>\n      </div>\n    </div>\n\n    <!-- MOBILE: Splide slider -->\n    <div class=\"splide\" id=\"brand-slider\">\n      <div class=\"splide__track\">\n        <ul class=\"splide__list\">\n          <li class=\"splide__slide\">\n            <div class=\"brand-card\">\n              <h3>Charmacy</h3>\n              <p>The fusion of <strong>Charm</strong> and <strong>Pharmacy</strong> represents our unique philosophy where <strong>beauty meets science</strong> in perfect harmony.</p>\n            </div>\n          </li>\n          <li class=\"splide__slide\">\n            <div class=\"brand-card\">\n              <h3>Milano</h3>\n              <p>Embodies Italian sophistication, artistry, and the timeless elegance that defines global beauty excellence.</p>\n            </div>\n          </li>\n          <li class=\"splide__slide\">\n            <div class=\"brand-card\">\n              <h3>Our Vision</h3>\n              <p>Performance-first, clean formulations rooted in global aesthetics, delivering results without compromise.</p>\n            </div>\n          </li>\n        </ul>\n      </div>\n    </div>\n\n  </div>\n</section>\n\n<script src=\"https://cdn.jsdelivr.net/npm/@splidejs/splide@4/dist/js/splide.min.js\"></script>\n<script>\n  // Only mount Splide on mobile; destroy/skip on desktop\n  let splideInstance = null;\n\n  function initSplide() {\n    if (window.innerWidth <= 768) {\n      if (!splideInstance) {\n        splideInstance = new Splide('#brand-slider', {\n          type        : 'loop',\n          perPage     : 1,\n          focus       : 'center',\n          gap         : '20px',\n          autoplay    : true,\n          interval    : 5000,\n          pauseOnHover: false,\n          arrows      : false,\n          pagination  : false,\n          padding: '10%'\n        }).mount();\n      }\n    } else {\n      if (splideInstance) {\n        splideInstance.destroy();\n        splideInstance = null;\n      }\n    }\n  }\n\n  initSplide();\n\n  // Re-evaluate on resize without requiring refresh\n  window.addEventListener('resize', initSplide);\n</script>",
