<script>
  function redirectToApp() {
    const userAgent = navigator.userAgent || navigator.vendor || window.opera;

    // iOS detection
    if (/iPad|iPhone|iPod/.test(userAgent) && !window.MSStream) {
      window.location.href = "https://apps.apple.com/in/app/charmacy-milano/id6752292994";
    }
    // Android detection
    else if (/android/i.test(userAgent)) {
      window.location.href = "https://play.google.com/store/apps/details?id=com.myshopify.charmacyindiastore.android&hl=en_IN";
    }
    // Fallback (desktop or other OS)
    else {
      // Optional: Redirect to a landing page or show a message
      alert("Please open this on your mobile device to download the app.");
    }
  }
</script>