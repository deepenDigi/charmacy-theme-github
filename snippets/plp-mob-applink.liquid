<style>
    .ma-slide {
    display: flex;
    flex-direction: column;
    border: 1px solid;
    border-radius: 10px;
    overflow: hidden;
}

.ma-top {
    display: flex;
    align-items: center;
    padding: 12px;
    background: #fff;
    color: #000;
    font-size: 12px;
}

.ma-top svg {
    width: 20px;
    height: 20px;
}

.ma-bottom {
    padding: 12px;
    font-size: 14px;
}

span.right-offer {
    margin-left: auto !important;
    margin-right: 0;
    align-self: flex-end;
}


.ma-top span {
    margin-left: 10px;
    font-size: 10px;
    max-width: 210px;
}
.ma-link {
    text-decoration: none;
    padding: 3px 15px;
    background: #64112f;
    border-radius: 20px;
    margin-right: 0;
    margin-left: auto !important;
    color: #fff;
    display: flex;
    align-items: center;
}
.ma-link svg {
    width: 14px;
    height: 14px;
    margin-left: 5px;
}
.mobile-app-link-wrap {
    max-width: 470px;
    margin: 0;
    width: 100%;
}
product-sticky-bar .mobile-app-link-wrap {
    display: none !important;
}
@media(max-width: 480px){
    button.ma-link {
        font-size: 11px;
        white-space: nowrap;
        padding: 6px 13px;
    }
}
</style>
