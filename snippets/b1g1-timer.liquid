 <!-- Daily Sale Timer -->
<div class="sale-timer" data-cutoff="00:00" style="margin-bottom:0;">
  <span class="sale-timer__icon">⏰</span>
  <span class="sale-timer__label">Sale Ends In :</span>

  <div class="sale-timer__block">
    <span class="sale-timer__part" data-h>00</span>
    <span class="sale-timer__unit">Hours</span>
  </div>
  <div class="sale-timer__block">
    <span class="sale-timer__part" data-m>00</span>
    <span class="sale-timer__unit">Minutes</span>
  </div>
  <div class="sale-timer__block">
    <span class="sale-timer__part" data-s>00</span>
    <span class="sale-timer__unit">Seconds</span>
  </div>
</div>

<style>
  .sale-timer {
    display: flex;
        align-items: center;
    font: 600 14px / 1.3 system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
    color: #8B0000;
    background: #fff5f5;
    border: 1px solid #f2dada;
    border-radius: 6px;
    padding: 8px 14px;
    width: 100%;
    margin: 0px 0;
    gap: 10px;
    justify-content: center;
  }
  .sale-timer__icon {
    font-size: 15px;
  }
  .sale-timer__label {
    margin-right: 10px;
  }
  .sale-timer__block {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .sale-timer__part {
    background: #fff;
    border: 1px solid #d77;
    border-radius: 4px;
    padding: 6px 8px;
    font-size: 16px;
    font-weight: bold;
    font-variant-numeric: tabular-nums;
    min-width: 32px;
    text-align: center;
  }
  .sale-timer__unit {
    font-size: 11px;
    font-weight: 500;
    margin-top: 2px;
    color: #8B0000;
  }
</style>

<script>
(function(){
  const root = document.currentScript.previousElementSibling.previousElementSibling;
  const getCutoff = () => {
    const hhmm = (root.getAttribute('data-cutoff') || '00:00').trim();
    const [hh, mm] = hhmm.split(':').map(v => parseInt(v,10));
    return Number.isFinite(hh) && Number.isFinite(mm) ? {hh, mm} : {hh:0, mm:0};
  };

  const hEl = root.querySelector('[data-h]');
  const mEl = root.querySelector('[data-m]');
  const sEl = root.querySelector('[data-s]');

  function nextCutoffDate(now){
    const {hh, mm} = getCutoff();
    const target = new Date(now);
    target.setHours(hh, mm, 0, 0);
    if (target <= now) target.setDate(target.getDate() + 1);
    return target;
  }

  function pad(n){ return n < 10 ? '0'+n : ''+n; }

  function render(){
    const now = new Date();
    const target = nextCutoffDate(now);
    let ms = target - now;

    if (ms <= 0){
      updateDisplay(0,0,0);
      return;
    }
    const totalSec = Math.floor(ms / 1000);
    const h = Math.floor(totalSec / 3600);
    const m = Math.floor((totalSec % 3600) / 60);
    const s = totalSec % 60;
    updateDisplay(h,m,s);
  }

  function updateDisplay(h,m,s){
    hEl.textContent = pad(h);
    mEl.textContent = pad(m);
    sEl.textContent = pad(s);
  }

  setInterval(render, 1000);
  render();
})();
</script>