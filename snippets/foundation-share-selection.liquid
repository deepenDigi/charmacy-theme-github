{% comment %}
  Snippet: shade-finder.liquid

  Use on product page:
  {% render 'shade-finder', product: product, shade_finder_id: 'main-shade-finder' %}

  Variant matching:
  Product variant title / SKU should contain shade code like MF-01, MF-02, MF-03 etc.
{% endcomment %}

{% assign sf_id = shade_finder_id | default: product.id | default: 'shade-finder' %}

<div id="ShadeFinder-{{ sf_id }}" class="sf-wrap">
  <div class="sf-card">
    <div class="sf-left">
      <p class="sf-eyebrow">03 - 15-Second Shade Finder</p>

      <h2 class="sf-heading">
        Find <em>your</em> match.
      </h2>

      <p class="sf-subtext">
        Two taps. We read your depth and undertone and point you to your shade, so you order once and love it.
      </p>

      <div class="sf-step">
        <p class="sf-step-title">1 · How deep is your skin?</p>

        <div class="sf-options" data-depth-options>
          <button type="button" class="sf-pill is-active" data-depth="fair">Fair</button>
          <button type="button" class="sf-pill" data-depth="light">Light</button>
          <button type="button" class="sf-pill" data-depth="medium">Medium</button>
          <button type="button" class="sf-pill" data-depth="tan">Tan</button>
          <button type="button" class="sf-pill" data-depth="deep">Deep</button>
        </div>
      </div>

      <div class="sf-step">
        <p class="sf-step-title">2 · Your undertone</p>

        <div class="sf-options" data-undertone-options>
          <button type="button" class="sf-pill sf-pill-wide is-active" data-undertone="warm">
            Warm <span>· golden</span>
          </button>

          <button type="button" class="sf-pill sf-pill-wide" data-undertone="neutral">
            Neutral
          </button>

          <button type="button" class="sf-pill sf-pill-wide" data-undertone="cool">
            Cool <span>· pink</span>
          </button>
        </div>
      </div>

      <p class="sf-tip">
        Tip: check your wrist veins, green = warm, blue = cool, both = neutral.
      </p>
    </div>

    <div class="sf-right">
      <div class="sf-result-box">
        <div class="sf-swatch" data-shade-swatch></div>

        <p class="sf-match-label" data-shade-code>Your Match · #MF-03</p>

        <h3 class="sf-name" data-shade-name>Cream Beige</h3>

        <p class="sf-description" data-shade-description>
          Fair depth, warm undertone. Tap below to preview it and add to cart.
        </p>

        <button type="button" class="sf-select-btn" data-shade-add>
          Select #MF-03
        </button>

        <p class="sf-status" data-shade-status aria-live="polite"></p>
      </div>
    </div>
  </div>

  <script type="application/json" data-product-variants>
    {% if product %}
      {{ product.variants | json }}
    {% else %}
      []
    {% endif %}
  </script>
</div>

<style>
  #ShadeFinder-{{ sf_id }} {
    padding: 40px 20px;
    background: #fbf8f2;
  }

  #ShadeFinder-{{ sf_id }} .sf-card {
    max-width: 1280px;
    margin: 0 auto;
    border-radius: 28px;
    padding: 64px 60px;
    background:
      radial-gradient(circle at 75% 28%, rgba(255,255,255,0.18), transparent 28%),
      linear-gradient(135deg, #650024 0%, #7a1735 52%, #54001f 100%);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 54px;
    align-items: center;
    box-shadow: 0 22px 60px rgba(61, 0, 22, 0.18);
  }

  #ShadeFinder-{{ sf_id }} .sf-eyebrow {
    margin: 0 0 14px;
    color: #e7c38f;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 6px;
    text-transform: uppercase;
  }

  #ShadeFinder-{{ sf_id }} .sf-heading {
    margin: 0;
    color: #fffaf4;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(38px, 4vw, 58px);
    line-height: 1;
    font-weight: 700;
    letter-spacing: -1.5px;
  }

  #ShadeFinder-{{ sf_id }} .sf-heading em {
    color: #e7c38f;
    font-style: italic;
    font-weight: 500;
  }

  #ShadeFinder-{{ sf_id }} .sf-subtext {
    max-width: 560px;
    margin: 18px 0 32px;
    color: rgba(255,255,255,0.88);
    font-size: 16px;
    line-height: 1.65;
    font-weight: 600;
  }

  #ShadeFinder-{{ sf_id }} .sf-step {
    margin-top: 26px;
  }

  #ShadeFinder-{{ sf_id }} .sf-step-title {
    margin: 0 0 12px;
    color: #e7c38f;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 3px;
    text-transform: uppercase;
  }

  #ShadeFinder-{{ sf_id }} .sf-options {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  #ShadeFinder-{{ sf_id }} .sf-pill {
    min-height: 45px;
    padding: 0 21px;
    border: 1px solid rgba(255,255,255,0.32);
    border-radius: 999px;
    background: transparent;
    color: #fff;
    font-size: 14px;
    font-weight: 800;
    cursor: pointer;
    transition: 0.22s ease;
  }

  #ShadeFinder-{{ sf_id }} .sf-pill span {
    color: rgba(255,255,255,0.55);
    font-weight: 700;
  }

  #ShadeFinder-{{ sf_id }} .sf-pill:hover {
    border-color: #e7c38f;
    transform: translateY(-1px);
  }

  #ShadeFinder-{{ sf_id }} .sf-pill.is-active {
    background: #e7c38f;
    color: #65001f;
    border-color: #e7c38f;
  }

  #ShadeFinder-{{ sf_id }} .sf-pill.is-active span {
    color: rgba(101,0,31,0.55);
  }

  #ShadeFinder-{{ sf_id }} .sf-tip {
    margin: 16px 0 0;
    color: rgba(255,255,255,0.58);
    font-family: monospace;
    font-size: 12px;
    font-weight: 700;
  }

  #ShadeFinder-{{ sf_id }} .sf-result-box {
    min-height: 360px;
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 18px;
    padding: 30px 34px;
    background:
      radial-gradient(circle at 55% 20%, rgba(255,255,255,0.12), transparent 26%),
      linear-gradient(135deg, rgba(255,255,255,0.04), rgba(255,255,255,0.09));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  #ShadeFinder-{{ sf_id }} .sf-swatch {
    width: 122px;
    height: 122px;
    border-radius: 50%;
    background: #efc197;
    border: 4px solid rgba(255,239,215,0.9);
    box-shadow: 0 16px 30px rgba(0,0,0,0.28);
    margin-bottom: 24px;
    transition: 0.25s ease;
  }

  #ShadeFinder-{{ sf_id }} .sf-match-label {
    margin: 0 0 10px;
    color: #e7c38f;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 4px;
    text-transform: uppercase;
  }

  #ShadeFinder-{{ sf_id }} .sf-name {
    margin: 0;
    color: #fffaf4;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 31px;
    line-height: 1.15;
  }

  #ShadeFinder-{{ sf_id }} .sf-description {
    max-width: 340px;
    margin: 15px 0 24px;
    color: rgba(255,255,255,0.72);
    font-size: 14px;
    line-height: 1.55;
    font-weight: 700;
  }

  #ShadeFinder-{{ sf_id }} .sf-select-btn {
    min-height: 48px;
    padding: 0 30px;
    border: 0;
    border-radius: 999px;
    background: #a7753f;
    color: #fff;
    font-size: 14px;
    font-weight: 900;
    cursor: pointer;
    transition: 0.2s ease;
  }

  #ShadeFinder-{{ sf_id }} .sf-select-btn:hover {
    transform: translateY(-1px);
    filter: brightness(1.08);
  }

  #ShadeFinder-{{ sf_id }} .sf-select-btn:disabled {
    cursor: not-allowed;
    opacity: 0.55;
  }

  #ShadeFinder-{{ sf_id }} .sf-status {
    min-height: 18px;
    margin: 13px 0 0;
    color: rgba(255,255,255,0.72);
    font-size: 12px;
    font-weight: 700;
  }

  @media screen and (max-width: 900px) {
    #ShadeFinder-{{ sf_id }} {
      padding: 32px 14px;
    }

    #ShadeFinder-{{ sf_id }} .sf-card {
      grid-template-columns: 1fr;
      gap: 34px;
      padding: 42px 24px;
      border-radius: 22px;
    }

    #ShadeFinder-{{ sf_id }} .sf-eyebrow {
      letter-spacing: 4px;
    }

    #ShadeFinder-{{ sf_id }} .sf-subtext {
      font-size: 15px;
    }

    #ShadeFinder-{{ sf_id }} .sf-options {
      gap: 8px;
    }

    #ShadeFinder-{{ sf_id }} .sf-pill {
      min-height: 42px;
      padding: 0 17px;
      font-size: 13px;
    }

    #ShadeFinder-{{ sf_id }} .sf-result-box {
      min-height: auto;
      padding: 30px 18px;
    }

    #ShadeFinder-{{ sf_id }} .sf-swatch {
      width: 104px;
      height: 104px;
    }
  }
</style>

<script>
  (function () {
    const root = document.getElementById('ShadeFinder-{{ sf_id }}');
    if (!root || root.dataset.loaded === 'true') return;
    root.dataset.loaded = 'true';

    const variantJson = root.querySelector('[data-product-variants]');
    const variants = variantJson ? JSON.parse(variantJson.textContent || '[]') : [];

    /*
      15 different shade combinations:
      5 skin depths x 3 undertones.

      To connect exact Shopify variants:
      Option 1: Add shade code in variant title or SKU, example MF-01, MF-02.
      Option 2: Add your real variant ID in variantId below.
    */

    const shadeData = {
      'fair|cool': {
        code: '#MF-01',
        name: 'Porcelain',
        color: '#f7d7bf',
        description: 'Fair depth, cool undertone. Best for fair skin with a soft pink base.',
        variantId: null
      },
      'fair|neutral': {
        code: '#MF-02',
        name: 'Fair Ivory',
        color: '#f2caa9',
        description: 'Fair depth, neutral undertone. Best for fair skin with balanced undertones.',
        variantId: null
      },
      'fair|warm': {
        code: '#MF-03',
        name: 'Cream Beige',
        color: '#efc197',
        description: 'Fair depth, warm undertone. Best for fair skin with a golden base.',
        variantId: null
      },

      'light|cool': {
        code: '#MF-04',
        name: 'Shell Rose',
        color: '#e8b792',
        description: 'Light depth, cool undertone. Best for light skin with a soft pink beige finish.',
        variantId: null
      },
      'light|neutral': {
        code: '#MF-05',
        name: 'Vanilla Beige',
        color: '#e6b182',
        description: 'Light depth, neutral undertone. Best for light skin with a balanced beige tone.',
        variantId: null
      },
      'light|warm': {
        code: '#MF-06',
        name: 'Soft Sand',
        color: '#dea36f',
        description: 'Light depth, warm undertone. Best for light skin with a golden beige tone.',
        variantId: null
      },

      'medium|cool': {
        code: '#MF-07',
        name: 'Rose Beige',
        color: '#d59b74',
        description: 'Medium depth, cool undertone. Best for medium skin with a rosy beige base.',
        variantId: null
      },
      'medium|neutral': {
        code: '#MF-08',
        name: 'Natural Beige',
        color: '#cf9469',
        description: 'Medium depth, neutral undertone. Best for medium skin with balanced warmth.',
        variantId: null
      },
      'medium|warm': {
        code: '#MF-09',
        name: 'Warm Nude',
        color: '#d4a26f',
        description: 'Medium depth, warm undertone. Best for medium skin with golden warmth.',
        variantId: null
      },

      'tan|cool': {
        code: '#MF-10',
        name: 'Chestnut Rose',
        color: '#b57545',
        description: 'Tan depth, cool undertone. Best for tan skin with a muted rosy brown tone.',
        variantId: null
      },
      'tan|neutral': {
        code: '#MF-11',
        name: 'Caramel',
        color: '#b97943',
        description: 'Tan depth, neutral undertone. Best for tan skin with a smooth caramel tone.',
        variantId: null
      },
      'tan|warm': {
        code: '#MF-12',
        name: 'Golden Tan',
        color: '#bd7c3f',
        description: 'Tan depth, warm undertone. Best for tan skin with a golden brown base.',
        variantId: null
      },

      'deep|cool': {
        code: '#MF-13',
        name: 'Espresso Rose',
        color: '#7e4529',
        description: 'Deep depth, cool undertone. Best for deep skin with a cool espresso finish.',
        variantId: null
      },
      'deep|neutral': {
        code: '#MF-14',
        name: 'Mocha Brown',
        color: '#84491f',
        description: 'Deep depth, neutral undertone. Best for deep skin with a balanced mocha tone.',
        variantId: null
      },
      'deep|warm': {
        code: '#MF-15',
        name: 'Toffee',
        color: '#8d4d22',
        description: 'Deep depth, warm undertone. Best for deep skin with a rich golden brown tone.',
        variantId: null
      }
    };

    let selectedDepth = 'fair';
    let selectedUndertone = 'warm';

    const swatch = root.querySelector('[data-shade-swatch]');
    const codeEl = root.querySelector('[data-shade-code]');
    const nameEl = root.querySelector('[data-shade-name]');
    const descEl = root.querySelector('[data-shade-description]');
    const addBtn = root.querySelector('[data-shade-add]');
    const statusEl = root.querySelector('[data-shade-status]');
    const depthButtons = root.querySelectorAll('[data-depth]');
    const undertoneButtons = root.querySelectorAll('[data-undertone]');

    function cleanText(value) {
      return String(value || '').toLowerCase().replace(/[^a-z0-9]/g, '');
    }

    function getVariantForShade(shade) {
      if (!shade) return null;

      if (shade.variantId) {
        return variants.find(function (variant) {
          return String(variant.id) === String(shade.variantId);
        }) || null;
      }

      const targetCode = cleanText(shade.code);
      const targetName = cleanText(shade.name);

      return variants.find(function (variant) {
        const haystack = cleanText([
          variant.title,
          variant.public_title,
          variant.sku,
          variant.option1,
          variant.option2,
          variant.option3
        ].join(' '));

        return haystack.includes(targetCode) || haystack.includes(targetName);
      }) || null;
    }

    function syncProductFormVariant(variant) {
      if (!variant) return;

      const productForms = document.querySelectorAll('form[action*="/cart/add"]');

      productForms.forEach(function (form) {
        const idInput = form.querySelector('[name="id"]');

        if (idInput) {
          idInput.value = variant.id;
          idInput.dispatchEvent(new Event('change', { bubbles: true }));
        }
      });

      const variantUrl = new URL(window.location.href);
      variantUrl.searchParams.set('variant', variant.id);
      window.history.replaceState({}, '', variantUrl.toString());
    }

    function setActiveButtons() {
      depthButtons.forEach(function (button) {
        button.classList.toggle('is-active', button.dataset.depth === selectedDepth);
      });

      undertoneButtons.forEach(function (button) {
        button.classList.toggle('is-active', button.dataset.undertone === selectedUndertone);
      });
    }

    function updateShade() {
      const key = selectedDepth + '|' + selectedUndertone;
      const shade = shadeData[key];

      if (!shade) return;

      swatch.style.background = shade.color;
      codeEl.textContent = 'Your Match · ' + shade.code;
      nameEl.textContent = shade.name;
      descEl.textContent = shade.description;
      addBtn.textContent = 'Select ' + shade.code;
      addBtn.dataset.selectedKey = key;
      statusEl.textContent = '';

      setActiveButtons();

      const matchedVariant = getVariantForShade(shade);

      if (matchedVariant) {
        syncProductFormVariant(matchedVariant);

        if (matchedVariant.available === false) {
          addBtn.textContent = shade.code + ' Sold Out';
          addBtn.disabled = true;
          statusEl.textContent = 'This shade is currently unavailable.';
        } else {
          addBtn.disabled = false;
        }
      } else {
        addBtn.disabled = false;
      }
    }

    depthButtons.forEach(function (button) {
      button.addEventListener('click', function () {
        selectedDepth = button.dataset.depth;
        updateShade();
      });
    });

    undertoneButtons.forEach(function (button) {
      button.addEventListener('click', function () {
        selectedUndertone = button.dataset.undertone;
        updateShade();
      });
    });

    addBtn.addEventListener('click', function () {
      const shade = shadeData[addBtn.dataset.selectedKey];

      if (!shade) return;

      const variant = getVariantForShade(shade);

      if (!variant) {
        statusEl.textContent = 'Variant not found. Add ' + shade.code.replace('#', '') + ' in variant SKU/title or add variantId in snippet code.';
        return;
      }

      if (variant.available === false) {
        statusEl.textContent = 'This shade is currently unavailable.';
        return;
      }

      addBtn.disabled = true;
      addBtn.textContent = 'Adding...';
      statusEl.textContent = '';

      fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({
          id: variant.id,
          quantity: 1
        })
      })
      .then(function (response) {
        if (!response.ok) {
          throw new Error('Cart add failed');
        }

        return response.json();
      })
      .then(function () {
        addBtn.textContent = 'Added';
        statusEl.textContent = shade.name + ' added to cart.';

        document.dispatchEvent(new CustomEvent('cart:refresh'));
        document.dispatchEvent(new CustomEvent('cart:updated'));

        setTimeout(function () {
          addBtn.disabled = false;
          addBtn.textContent = 'Select ' + shade.code;
        }, 1400);
      })
      .catch(function () {
        addBtn.disabled = false;
        addBtn.textContent = 'Select ' + shade.code;
        statusEl.textContent = 'Could not add this shade. Please try again.';
      });
    });

    updateShade();
  })();
</script>