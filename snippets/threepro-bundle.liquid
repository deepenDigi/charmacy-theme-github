{% assign bundle_products = product.metafields.custom.bundle_products.value %}

<div id="bundle-products">


    <div id="bundle-wrapper">
        {% for bundle_product in bundle_products %}
        <!-- {% assign product_obj = all_products[bundle_product] %} -->
        <div class="bundle-item" data-product-handle="{{ bundle_product.handle }}"
            data-product-id="{{ bundle_product.id }}">
            <div class="variant-feature-image">
                <div class="vf-img"></div>
            </div>
            <!-- <div class="variant-details">
                <h4 class="only-desk">{{ bundle_product.title }}</h4>
            </div>
            <div class="variant-options" id="variant-options-{{ forloop.index }}"></div> -->

            <!-- <div class="price">Price: <span class="bundle-price" data-price="{{ bundle_product.price | money_without_currency }}">{{ bundle_product.price | money }}</span></div> -->
        </div>

        {% assign first_variant = bundle_product.variants.first %}
        {% assign total_price = total_price | plus: first_variant.price %}
        {% endfor %}
    </div>



    <button id="add-bundle-to-cart" class="button">ADD TO CART</button>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const bundleItems = document.querySelectorAll(".bundle-item");
  const cartButton = document.getElementById("add-bundle-to-cart");
  let selectedVariants = [];

  async function fetchAllVariants(productHandle, index) {
    try {
      const response = await fetch(`/products/${productHandle}.js`);
      const data = await response.json();
      const bundleItem = document.querySelector(`.bundle-item[data-product-handle="${productHandle}"]`);

      data.variants.forEach((variant, variantIndex) => {
       const vfImg = bundleItem.querySelector('.vf-img');
      vfImg.innerHTML = ""; // Clear existing content
      
      data.variants.forEach((variant) => {
        if (variant.featured_image) {
          const wrapper = document.createElement("div");
          wrapper.classList.add("variant-img-wrapper");
      
          const img = document.createElement("img");
          img.src = `${variant.featured_image.src}&width=400`;
          img.alt = variant.title;
          img.title = variant.title;        
          img.style.objectFit = "cover";
          img.style.display = "block";
      
          

          const span = document.createElement("span");
          span.setAttribute('class', 'iteminfo');
          span.innerHTML = img.title;

          wrapper.appendChild(img);
          wrapper.appendChild(span);
          vfImg.appendChild(wrapper);
        }
      });


        selectedVariants.push({
          id: variant.id,
          price: variant.price / 100,
          handle: productHandle,
          title: variant.title,
          sku: variant.sku || 'N/A'
        });
      });
    } catch (err) {
      console.error("Failed to fetch variants for", productHandle, err);
    }
  }

  async function init() {
    for (let i = 0; i < bundleItems.length; i++) {
      const handle = bundleItems[i].getAttribute("data-product-handle");
      await fetchAllVariants(handle, i);
    }
  }

  init();

  cartButton.addEventListener("click", async () => {
    if (selectedVariants.length === 0) {
      alert("No variants found to add.");
      return;
    }

    const productHandle = window.location.pathname.split("/products/")[1]?.split("/")[0] || `custom-${Date.now()}`;
    const properties = {
      "Bundle ID": `BUNDLE-${productHandle}`,
      "Product Count": selectedVariants.length
    };

    selectedVariants.forEach((variant, i) => {
      const price = variant.price.toFixed(0);
      const value = `${variant.sku}/${price}/1`;
      properties[`_bundle_product${i + 1}`] = value;
    });

    const bundleProduct = await fetch(`/products/${productHandle}.js`).then(r => r.json());
    const bundleProductVariantId = bundleProduct.variants[0]?.id;

    if (!bundleProductVariantId) {
      alert("Bundle product variant not found.");
      return;
    }

    const response = await fetch('/cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify({
        id: bundleProductVariantId,
        quantity: 1,
        properties: properties
      })
    });

    if (response.ok) {
      document.dispatchEvent(new CustomEvent('cart:build'));
      setTimeout(() => {
        document.querySelector('.js-drawer-open-cart').click();
      }, 500);
    } else {
      alert("Failed to add bundle to cart");
    }
  });
});
</script>