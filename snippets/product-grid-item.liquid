<script>
  (function () {
    function fixJudgeMe() {
      document.querySelectorAll('.jdgm-preview-badge').forEach(function (badge) {
        const starsWrap = badge.querySelector('.jdgm-prev-badge__stars');
        const textWrap = badge.querySelector('.jdgm-prev-badge__text');
        const box = badge.querySelector('.jdgm-prev-badge');

        if (!starsWrap || !textWrap || !box) return;

        // rating
        const score = starsWrap.getAttribute('data-score') || starsWrap.dataset.score;

        // review count
        const count = box.getAttribute('data-number-of-reviews');

        // inject avg
        if (score && !textWrap.querySelector('.jdgm-custom-avg')) {
          const avg = document.createElement('span');
          avg.className = 'jdgm-custom-avg';
          avg.textContent = score;
          textWrap.prepend(avg);
        }

        // attach count for CSS
        if (count) {
          textWrap.setAttribute('data-count', count);
        }
      });
    }

    document.addEventListener('DOMContentLoaded', function () {
      fixJudgeMe();
      setTimeout(fixJudgeMe, 800);
      setTimeout(fixJudgeMe, 1500);
    });

    new MutationObserver(fixJudgeMe).observe(document.body, { childList: true, subtree: true });
  })();
</script>
