<div class="countdown-container dd template-{{ template }}">
    <h2>Sale Ends in </h2>
    <div class="countdown">
      <div class="countdown-item">
        <span id="days">00</span>
        <span class="separator">:</span>
        <span class="label">DAYS</span>
      </div>
      <div class="countdown-item">
        <span id="hours">00</span>
        <span class="separator">:</span>
        <span class="label">HOURS</span>
      </div>
      <div class="countdown-item">
        <span id="minutes">00</span>
        <span class="separator">:</span>
        <span class="label">MINUTES</span>
      </div>
      <div class="countdown-item">
        <span id="seconds">00</span>
        <span class="label">SECONDS</span>
      </div>
    </div>
  </div>

 
  

<script>
// Define an array of target dates in sequence
const targetDates = [
  new Date("2026-05-29T23:59:59").getTime(),
  new Date("2026-05-30T23:59:59").getTime(),
  new Date("2026-05-31T23:59:59").getTime(),
  new Date("2026-06-01T23:59:59").getTime(),
  new Date("2026-06-02T23:59:59").getTime(),
  new Date("2026-06-03T23:59:59").getTime(),
  new Date("2026-06-04T23:59:59").getTime(),
  new Date("2026-06-05T23:59:59").getTime(),
  new Date("2026-06-06T23:59:59").getTime()
];

let currentTargetIndex = 0; // Start with the first target date

function updateCountdown() {
  const now = new Date().getTime();
  const timeRemaining = targetDates[currentTargetIndex] - now;

  if (timeRemaining >= 0) {
    const days = Math.floor(timeRemaining / (1000 * 60 * 60 * 24));
    const hours = Math.floor((timeRemaining % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const minutes = Math.floor((timeRemaining % (1000 * 60 * 60)) / (1000 * 60));
    const seconds = Math.floor((timeRemaining % (1000 * 60)) / 1000);

    document.getElementById("days").textContent = days.toString().padStart(2, "0");
    document.getElementById("hours").textContent = hours.toString().padStart(2, "0");
    document.getElementById("minutes").textContent = minutes.toString().padStart(2, "0");
    document.getElementById("seconds").textContent = seconds.toString().padStart(2, "0");
  } else {
    currentTargetIndex++; // Move to the next target date

    if (currentTargetIndex < targetDates.length) {
      updateCountdown(); // Start the next countdown immediately
    } else {
      document.querySelector(".countdown-container").innerHTML = "<h2>Countdown Ended!</h2>";
      clearInterval(timerInterval);
    }
  }
}

const timerInterval = setInterval(updateCountdown, 1000);
updateCountdown();



  
