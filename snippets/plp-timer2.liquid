<style>
    .countdown-container{
        text-align: center;
    }
    .countdown-container h2{
        margin: 15px 10px;
        padding: 0px;
    }
.countdown {
    display: flex;
    justify-content: center;
    align-items: flex-end;
    gap: 20px;
    font-size:10px;
}

.countdown-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  line-height: 30px;
   font-size:0px;
}

.countdown-item span:first-child {
  font-size: 25px;
  /* color: #790f0f; */
  color: #c54e71;
}
.countdown-container h2{
  color: #bf3f64;
}

.countdown-item .separator {
  position: absolute;
  right: -18px; /* Adjust spacing between numbers and separators */
  top: 0px; /* Align separator with the middle of the number */
  
  font-size: 20px;
    color: #9C2D41;
}

.countdown-item .label {
  font-size: 10px;
  color: #555;
  text-transform: uppercase;
}

.countdown-item:last-child .separator {
  display: none; /* Hide the separator after the last countdown item */
}

/* ======= 21-01-25 ===========   */
.countdown-container {
    position: relative;
    padding: 0px 0;
    overflow: hidden;
}

.countdown-container:before {
    content: '';
    position: absolute;
    width: 110%;
    height: 100%;
    /* background: url(https://i.pinimg.com/736x/f5/a1/98/f5a198fd7dce8a792a58d335e04921ce.jpg); */
    background-size: cover;
    left: -10px;
    top: 0;
    background-repeat: no-repeat;
    background-position: 10px;
}

.countdown-container > h2 {
    position: relative;
}
.countdown-container.dd.template-product {
    margin-top: -10px;
    margin-bottom: 15px;
}
 @media(max-width: 768px){
   .countdown-container:before{
     background-size: cover;
   }
   .countdown-container > h2{
        font-size: 13px;
   }
 } 

  .countdown .countdown-item:first-child {
    /* display: none; */
}

  
  #offer-bg-img{
    margin-top: -120px;
  }
  .countdown-item:first-child {
    display: none;
}
.countdown-container.dd.template-product h2 {
    font-size: 20px;
    margin-bottom: 10px;

}


@media(min-width: 769px){
  {% if template contains 'product' %}
  .countdown-container{
      padding: 0px 0;
  }  
  {% endif %}

   #offer-bg-img{
    margin-top: -135px;
  }
}
body.template-product\.women-shirts .countdown-container,
body.template-product\.men .countdown-container{
    display: block;
visibility: hidden;
}
