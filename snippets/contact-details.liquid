<style>
.wrapper-contact {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}

.wrapper-contact .page-width.page-width--narrow {
  margin: 0;
}

.ci-contact-card {
  width: 100%;
  max-width: 980px;
  color: #1f1f1f;
  margin: 40px 0;
}

.ci-contact-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border: 1px solid #eadbd8;
  border-radius: 14px;
  overflow: hidden;
  background: #ffa5c60f;
}

.ci-contact-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  text-align: center;
  gap: 10px;
  min-height: 130px;
  padding: 26px 18px 22px;
  border-right: 1px solid #eadbd8;
}

.ci-contact-item:last-child {
  border-right: 0;
}

.ci-contact-icon {
  width: 56px;
  height: 56px;
  min-width: 56px;
  border-radius: 50%;
  background: #64112f;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
}

.ci-contact-icon svg {
  width: 23px;
  height: 23px;
}

.ci-contact-label {
  display: block;
  margin: 5px;
  font-size: 11px;
  line-height: 1.2;
  font-weight: 700;
  color: #77706f;
  letter-spacing: 1.2px;
  text-transform: uppercase;
}

.ci-contact-value {
  display: block;
  max-width: 100%;
  font-size: 16px;
  line-height: 1.35;
  color: #202020;
  word-break: normal;
  overflow-wrap: anywhere;
}

.ci-contact-value a {
  color: inherit;
  text-decoration: none;
}

@media (max-width: 768px) {
  .ci-contact-list {
    /* grid-template-columns: 1fr; */
    border-radius: 0;
  }

  .ci-contact-label{
      font-size: 9px;
  }
  .ci-contact-item {
    min-height: auto;
    border-right: 0;
    border-bottom: 1px solid #eadbd8;
    padding: 20px 6px;
  }

  .ci-contact-icon{
    width: 45px;
    height: 45px;
    min-width: 45px;
  }

  .ci-contact-value{
    font-size: 12px;
  }

  .ci-contact-item:last-child {
    border-bottom: 0;
  }
}
</style>

<div class="ci-contact-card">
  <div class="ci-contact-list">
    <div class="ci-contact-item">
      <div class="ci-contact-icon">
        <svg viewBox="0 0 24 24" fill="none">
          <path d="M6.6 10.8C8.2 14 10 15.8 13.2 17.4L15.3 15.3C15.6 15 16 14.9 16.4 15.1C17.6 15.5 18.8 15.7 20 15.7C20.6 15.7 21 16.1 21 16.7V20C21 20.6 20.6 21 20 21C10.6 21 3 13.4 3 4C3 3.4 3.4 3 4 3H7.3C7.9 3 8.3 3.4 8.3 4C8.3 5.2 8.5 6.4 8.9 7.6C9 8 9 8.4 8.7 8.7L6.6 10.8Z" fill="currentColor"/>
        </svg>
      </div>
      <div>
        <span class="ci-contact-label">Phone</span>
        <span class="ci-contact-value">+91-9167001818</span>
      </div>
    </div>

    <div class="ci-contact-item">
      <div class="ci-contact-icon">
        <svg viewBox="0 0 24 24" fill="none">
          <path d="M4 6H20C20.6 6 21 6.4 21 7V17C21 17.6 20.6 18 20 18H4C3.4 18 3 17.6 3 17V7C3 6.4 3.4 6 4 6ZM12 13L19 8H5L12 13ZM5 16H19V10.4L12 15.4L5 10.4V16Z" fill="currentColor"/>
        </svg>
      </div>
      <div>
        <span class="ci-contact-label">Email</span>
        <span class="ci-contact-value">support@charmacy-india.com</span>
      </div>
    </div>

    <div class="ci-contact-item">
      <div class="ci-contact-icon">
        <svg viewBox="0 0 24 24" fill="none">
          <path d="M12 2C6.5 2 2 6.5 2 12S6.5 22 12 22 22 17.5 22 12 17.5 2 12 2ZM12 20C7.6 20 4 16.4 4 12S7.6 4 12 4 20 7.6 20 12 16.4 20 12 20ZM13 7H11V13L16 16L17 14.3L13 12V7Z" fill="currentColor"/>
        </svg>
      </div>
      <div>
        <span class="ci-contact-label">Support Hours</span>
        <span class="ci-contact-value">Mon-Sat from 10 am to 6 pm</span>
      </div>
    </div>
  </div>
</div>