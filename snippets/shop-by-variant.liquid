<script>
  document.addEventListener("DOMContentLoaded", function () {
    let selectedVariants = new Set();
    let addToCartButton = document.getElementById("add-selected-to-cart");
    let resetButton = document.getElementById("resetBtn");
    let modal = document.getElementById("upsell-modal");
    let cartItemsContainer = document.getElementById("cart-items-container"); // Fix: Defined properly

    let progressBar = document.getElementById("progress-bar");
    let step1 = document.getElementById("step-1");
    let step2 = document.getElementById("step-2");
    let step3 = document.getElementById("step-3");

    function updateProgressBar() {
        let stepCount = selectedVariants.size;
        progressBar.style.width = (stepCount / 3) * 100 + "%";
        step1.classList.toggle("completed", stepCount >= 1);
        step2.classList.toggle("completed", stepCount >= 2);
        step3.classList.toggle("completed", stepCount >= 3);

        if (stepCount === 3) {
            addToCartButton.classList.add("active");
            addToCartButton.removeAttribute("disabled");
        } else {
            addToCartButton.classList.remove("active");
            addToCartButton.setAttribute("disabled", "true");
        }
    }

    function updateActiveVariants() {
        fetch('/cart.js')
            .then(response => response.json())
            .then(cart => {
                let variantsInCart = new Set(cart.items.map(item => item.variant_id));

                document.querySelectorAll(".variant-item").forEach(button => {
                    let variantId = parseInt(button.getAttribute("data-variant-id"));
                    if (variantsInCart.has(variantId)) {
                        button.classList.add("active");
                        button.setAttribute("disabled", "true");
                        selectedVariants.add(variantId);
                    }
                });

                updateProgressBar();
            });
    }

    document.querySelectorAll(".variant-item").forEach(button => {
        button.addEventListener("click", function () {
            let variantId = this.getAttribute("data-variant-id");

            if (selectedVariants.has(variantId)) {
                selectedVariants.delete(variantId);
                this.classList.remove("active");
            } else {
                selectedVariants.add(variantId);
                this.classList.add("active");
            }

            addToCartButton.style.display = selectedVariants.size > 0 ? "block" : "none";
            updateProgressBar();
        });
    });

    addToCartButton.addEventListener("click", function () {
        if (selectedVariants.size === 0) return;

        let itemsToAdd = Array.from(selectedVariants).map(variantId => ({ id: variantId, quantity: 1 }));

        fetch("/cart/add.js", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ items: itemsToAdd })
        })
        .then(response => response.json())
        .then(cart => {
            cartItemsContainer.innerHTML = ''; // Clear existing items

            selectedVariants.forEach(variantId => {
                let variantButton = document.querySelector(`.variant-item[data-variant-id="${variantId}"]`);
                let variantTitle = variantButton.querySelector(".var-con h3").innerText;
                let variantImgSrc = variantButton.querySelector(".var-img img").src;

                const itemElement = document.createElement('div');
                itemElement.classList.add('cart-item');
                itemElement.innerHTML = `
                    <img src="${variantImgSrc}" alt="${variantTitle}" width="100">
                    <p>${variantTitle}</p>
                `;
                cartItemsContainer.appendChild(itemElement);
            });

            modal.style.display = 'block'; // Show modal
            // monster_refresh()
        })
        .catch(error => console.error("Error:", error));
    });

    resetButton.addEventListener("click", function () {
        selectedVariants.clear();

        document.querySelectorAll(".variant-item").forEach(button => {
            button.classList.remove("active");
            button.removeAttribute("disabled");
        });

        progressBar.style.width = "0%";
        step1.classList.remove("completed");
        step2.classList.remove("completed");
        step3.classList.remove("completed");

        addToCartButton.classList.remove("active");
        addToCartButton.setAttribute("disabled", "true");
        addToCartButton.style.display = "none";
    });

    document.getElementById("continue-shopping").addEventListener("click", function () {
        modal.style.display = "none";
        window.location.reload()
    });

    window.addEventListener("click", function (event) {
        if (event.target === modal) {
            modal.style.display = "none";
        }
    });

    updateActiveVariants();
});

</script>
      


