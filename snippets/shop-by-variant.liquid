  <script>
    document.addEventListener("DOMContentLoaded", function () {
      let selectedVariants = new Set(); // Store selected variants
      let addToCartButton = document.getElementById("add-selected-to-cart");
      let resetButton = document.getElementById("resetBtn"); // The reset button
      // ======== progress bar ==========
      let progressBar = document.getElementById("progress-bar");
      let step1 = document.getElementById("step-1");
      let step2 = document.getElementById("step-2");
      let step3 = document.getElementById("step-3");
  
      function updateProgressBar() {
        let stepCount = selectedVariants.size;
        progressBar.style.width = (stepCount / 3) * 100 + "%";
        step1.classList.toggle("completed", stepCount >= 1);
        step2.classList.toggle("completed", stepCount >= 2);
        step3.classList.toggle("completed", stepCount >= 3);
  
  
        if (stepCount === 3) {
          addToCartButton.classList.add("active");
          addToCartButton.removeAttribute("disabled");
        } else {
          addToCartButton.classList.remove("active");
          addToCartButton.setAttribute("disabled", "true");
        }
        
      }
  
      // ======== Update active variants based on cart contents =======
      function updateActiveVariants() {
        fetch('/cart.js')
          .then(response => response.json())
          .then(cart => {
            let variantsInCart = new Set(cart.items.map(item => String(item.variant_id)));
  
            document.querySelectorAll(".variant-item").forEach(button => {
              let variantId = String(button.getAttribute("data-variant-id"));
              if (variantsInCart.has(variantId)) {
                button.classList.add("active");
                
                button.setAttribute("disabled", "true");
                selectedVariants.add(variantId); // Add to selected if it's in the cart
              }
            });
  
            updateProgressBar();
          });
      }
  
      // ============ variant add ===========
      document.querySelectorAll(".variant-item").forEach(button => {
        button.addEventListener("click", function () {
          let variantId = String(this.getAttribute("data-variant-id"));
          
          if (selectedVariants.has(variantId)) {
            selectedVariants.delete(variantId);
            this.classList.remove("active");
          } else {
            selectedVariants.add(variantId);
            this.classList.add("active");
          }
  
          addToCartButton.style.display = selectedVariants.size > 0 ? "block" : "none";
           updateProgressBar();
        });
      });
  
      addToCartButton.addEventListener("click", function () {
        if (selectedVariants.size === 0) return;

        // Add the MAIN product, store selected bundle variants in properties
        const mainVariantId = {{ product.selected_or_first_available_variant.id }};
        const shadeIds = Array.from(selectedVariants);
        const props = {};

        shadeIds.forEach((id, idx) => {
          const btn = document.querySelector(`.variant-item[data-variant-id="${id}"]`);
          const title = btn?.dataset?.title || `Shade ${idx + 1}`;
          const sku = btn?.dataset?.sku || "SKU missing";
          {% comment %} const variant = product.variants.find(v => v.id == item.variant_id); {% endcomment %}
          {% comment %} const price = (variant.price / 100).toFixed(0); {% endcomment %}
          const quantity = 1;
          props[`shade ${idx + 1}`] = `${title}`;
           props[`_bundle_product ${idx + 1}`] = `${sku}/${quantity}`;
          {% comment %} props[`Bundle shade ${idx + 1} ID`] = id; {% endcomment %}
        });
        {% comment %} props["Bundle count"] = shadeIds.length; {% endcomment %}

        fetch("/cart/add.js", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            items: [
              {
                id: mainVariantId,
                quantity: 1,
                properties: props
              }
            ]
          })
        })
        .then(response => response.json())
        .then(data => {
          console.log("Cart updated:", data);
           document.dispatchEvent(new CustomEvent('cart:build'));
            document.querySelector(".js-drawer-open-cart").click();
        })
        .catch(error => console.error("Error:", error));
      });
  
      // ============ Reset button functionality ============
      resetButton.addEventListener("click", function () {
        // Clear selected variants
        selectedVariants.clear();
  
        // Remove active class from all variant buttons
        document.querySelectorAll(".variant-item").forEach(button => {
          button.classList.remove("active");
          button.removeAttribute("disabled");
        });
  
        // Reset progress bar
        progressBar.style.width = "0%";
        step1.classList.remove("completed");
        step2.classList.remove("completed");
        step3.classList.remove("completed");
  
        // Disable the "Add to Cart" button and hide it
        addToCartButton.classList.remove("active");
        addToCartButton.setAttribute("disabled", "true");
        addToCartButton.style.display = "none";
      });
  
      updateActiveVariants();
    });
  </script>
  
  
