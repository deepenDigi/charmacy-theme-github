<style>
  .swatch {
    display: inline-block;
    padding: 6px 12px;
    margin: 4px;
    border: 1px solid transparent;
    cursor: pointer;
    border-radius: 10px;
    background: #f8f8f8;
  }
  .swatch.active { border-color: #000; font-weight: bold; }

  /* OOS swatches */
  .swatch.oos{ cursor: not-allowed; position: relative; }
  .swatch.oos::after{
    content:""; position:absolute; left:0; right:3px; top:50%;
    height:1px; width:100%; background:#000; transform:rotate(-45deg);
    pointer-events:none;
  }

  .bundle-item {
    background:#fff3e6; padding:10px; margin-bottom:20px; display:flex; gap:1rem;
    border:1px solid #be3254; border-radius:8px; flex-wrap:wrap;
  }
  .vf-img { background:#fff; width:100%; height:100%; border-radius:8px; }
  .bundle-item .variant-details h4>span { color:#a3234f!important; display:block!important; margin-top:6px; }

  h1.h2.product-single__title { font-size:1.8rem; margin-bottom:1rem; letter-spacing:0!important; }

  .bundle-total div:nth-child(1), .bundle-total div:nth-child(2){ display:inline-block; font-size:1.1rem; }
  .bundle-total div:nth-child(1){ font-size:1.6rem; letter-spacing:0; font-weight:600; color:#9a1c49; padding-right:4px; }

  #bundle-products { border:2px solid #be3254; padding:1rem; border-radius:8px; }
  #bundle-products h3 {
    font-size:1rem; margin:0; padding:15px; color:#fff; text-transform:uppercase; font-weight:600;
    background: radial-gradient(circle, #ce3e58 55%, #9e1b4b);
    text-align:center; margin-bottom:20px; border-radius:6px;
  }

  .bundle-total { margin-bottom:20px; }
  .bundle-total div:nth-child(2){ margin-left:4px; text-decoration:line-through; color:#64112fad; }
  .dic-flag { display:inline-block; font-size:1.1rem; margin-left:4px; color:#64112f; font-weight:600; font-family:'Poppins'; }
  #add-bundle-to-cart { width:100%; height:45px; line-height:45px; background:#64112f; color:#fff; }

  .bundle-item .variant-details h4, .bundle-item .variant-details h4>span {
    display:inline-block; font-size:.9rem!important; flex-wrap:wrap; margin-bottom:4px; text-transform:uppercase;
  }
  .variant-feature-image { width:15%; }
  button.swatch.active { box-shadow: rgba(255,255,255,.2) 0 0 0 1px inset, rgba(0,0,0,.9) 0 0 0 1px; }
  .variant-details { width:75%; }
  .selected-shade-name { color:#000; display:block; font-weight:700; font-size:18px; }

  @media(max-width:768px){
    .vf-img { border:none; width:70px!important; height:70px!important; }
    .bundle-total div:nth-child(1){ font-size:1.4rem; }
    .variant-feature-image { width:25%; }
    .bundle-item { gap:5px; align-items:center; margin-bottom:6px; }
    .variant-details { width:70%; }
    .swatch { width:30px!important; height:30px!important; }
    #bundle-products { border:none; padding:0; }
    h1.h2.product-single__title { font-size:15px!important; }
    .pack-2 { font-size:11px; }
    #bundle-products h3 { padding:7px; font-size:12px; margin-bottom:9px; }
    .bundle-item .variant-details h4, .bundle-item .variant-details h4>span { font-size:.8rem!important; }
  }

  .pack-2 { font-size:15px; text-transform:uppercase; color:gray; margin-bottom:10px; }
  h1.h2.product-single__title { font-size:20px; }
  .hidden { display:none!important; }

  /* === Hurry toast (80% width) === */
  .hurry-toast {
    position: fixed; left: 50%; bottom: 24px;
    transform: translateX(-50%) translateY(20px) scale(.98);
    background: #64112f; color: #fff;
    padding: 12px 16px; border-radius: 12px;
    font-weight: 800; font-size: 14px; line-height: 1.25;
    box-shadow: 0 12px 30px rgba(0,0,0,.25);
    opacity: 0; z-index: 100000; pointer-events: none;
    transition: opacity .25s ease, transform .25s ease;

    width: 80%; max-width: 80%; text-align: center;
  }
  .hurry-toast.show { opacity: 1; transform: translateX(-50%) translateY(0) scale(1); }
  .hurry-inner { display: flex; align-items: center; justify-content:center; gap: 8px; flex-wrap: wrap; }

  .hurry-icon { font-size: 18px; line-height: 1; display: inline-block; filter: drop-shadow(0 2px 4px rgba(0,0,0,.25)); }
  @keyframes flame {
    0% { transform: translateY(0) scale(1); opacity: .95; }
    50% { transform: translateY(-1px) scale(1.12); opacity: 1; }
    100% { transform: translateY(0) scale(1); opacity: .95; }
  }
  .hurry-icon { animation: flame .6s ease-in-out infinite; }

  .hurry-text { letter-spacing: .3px; }
  @keyframes wiggle { 0%,100% { transform: rotate(0deg); } 25% { transform: rotate(-1.5deg); } 75% { transform: rotate(1.5deg); } }
  .hurry-text { animation: wiggle 1.1s ease-in-out 2; }

  .hurry-progress { height: 3px; background: rgba(255,255,255,.35); border-radius: 999px; overflow: hidden; margin-top: 8px; }
  .hurry-progress > i { display:block; height:100%; width:100%; background: #fff; transform-origin: left; animation: drain 1.9s linear forwards; }
  @keyframes drain { from { transform: scaleX(1); } to { transform: scaleX(0); } }

  /* Global confetti rain */
  .confetti {
    position: fixed; top: -8px; width: 8px; height: 8px; border-radius: 2px;
    opacity: .95; pointer-events: none; z-index: 99999;
    animation: confetti-fall var(--t,1.4s) linear forwards;
    transform: translate3d(var(--x,0), -10px, 0) rotate(0deg);
  }
  @keyframes confetti-fall {
    to { transform: translate3d(var(--xEnd, 0), 110vh, 0) rotate(540deg); opacity: 0; }
  }

  /* === PARTY POPPER (streamers + emojis + ring) === */
  /* streamer pieces */
  .popper-piece {
    position: fixed; width: 6px; height: 14px; border-radius: 2px;
    opacity: 0.98; pointer-events: none; z-index: 100001;
    transform: translate(-50%, -50%) translate(0,0) rotate(0deg);
    animation: popper-fly var(--dur,900ms) cubic-bezier(.2,.8,.2,1) forwards;
  }
  @keyframes popper-fly {
    70% { transform: translate(-50%, -50%) translate(var(--dx), var(--dy)) rotate(var(--rot)); opacity: 1; }
    100% { transform: translate(-50%, -50%) translate(calc(var(--dx)*1.15), calc(var(--dy)*1.1)) rotate(calc(var(--rot) + 90deg)); opacity: 0; }
  }

  /* emoji burst */
  .emoji-pop {
    position: fixed; font-size: var(--fz,18px); line-height: 1;
    z-index: 100001; pointer-events: none; filter: drop-shadow(0 2px 4px rgba(0,0,0,.25));
    transform: translate(-50%, -50%) translate(0,0) scale(.9);
    animation: emoji-float var(--edur,1500ms) ease-out forwards;
  }
  @keyframes emoji-float {
    60% { transform: translate(-50%, -50%) translate(var(--edx), var(--edy)) scale(1.1); opacity: 1; }
    100% { transform: translate(-50%, -50%) translate(calc(var(--edx)*1.2), calc(var(--edy)*1.15)) scale(1); opacity: 0; }
  }

  /* expanding ring */
  .popper-ring {
    position: fixed; left: 0; top: 0; width: 12px; height: 12px; border-radius: 999px;
    border: 2px solid rgba(255,255,255,.9); box-shadow: 0 0 0 2px rgba(255,255,255,.25) inset;
    transform: translate(-50%, -50%) scale(.2); opacity: .9; pointer-events: none; z-index: 100001;
    animation: ring-boom 950ms ease-out forwards;
  }
  @keyframes ring-boom {
    80% { transform: translate(-50%, -50%) scale(12); opacity: .25; }
    100% { transform: translate(-50%, -50%) scale(14); opacity: 0; }
  }

  /* OPTIONAL: popup dialog (if used) to 80% width too */
  .bundle-popup__dialog { width: 80% !important; max-width: 80% !important; }
</style>

{% assign bundle_products = product.metafields.custom.bundle_products.value %}
{% if product.title == 'CMC PRO-PORE CONCEAL PRIMER + SET & FIX LOOSE POWDER + MATTE FOUNDATION' %}
  <h3 class="pack-2">Pack of 3</h3>
{% elsif product.title == 'Karwa Chauth Hamper' %}
  <h3 class="pack-2">Pack of 5</h3>
{% elsif product.title == 'CMC MATTE FOUNDATION + CONCEALER + HD Cover Compact Powder' or product.title == 'CMC HD Cover Compact Powder + STUNNING LONGSTAY LIQUID LIP + SKETCH EYELINER - Pack of 3 (bundle)' or product.title == 'CMC MATTE FOUNDATION + CHEEK ENHANCER + STAR DUST HIGHLIGHTERS - Pack of 3 (Bundle)' or product.title == 'CMC PRO-PORE CONCEAL PRIMER + SET & FIX LOOSE POWDER + MATTE FOUNDATION - Pack of 3 ( Bundle )'
or  product.title == 'CMC MATTE FOUNDATION + CONCEALER + HD Cover Compact Powder - Pack of 3 ( Bundle )'%}
  <h3 class="pack-2">Pack of 3</h3>
{% else %}
  <h3 class="pack-2">Pack of 2</h3>
{% endif %}

<div id="bundle-products">
  <h3>Choose your shade</h3>

  <div id="bundle-wrapper">
    {% for bundle_product in bundle_products %}
      <div class="bundle-item" data-product-handle="{{ bundle_product.handle }}" data-product-id="{{ bundle_product.id }}">
        <div class="variant-feature-image"><div class="vf-img"></div></div>
        <div class="variant-details">
          <h4 class="only-desk">
            {{ bundle_product.title }}
            <span class="selected-shade-name"></span>
          </h4>
        </div>
        <div class="variant-options" id="variant-options-{{ forloop.index }}"></div>
      </div>

      {% assign first_variant = bundle_product.variants.first %}
      {% assign total_price = total_price | plus: first_variant.price %}
    {% endfor %}
  </div>

  <button id="add-bundle-to-cart" class="button">ADD TO CART</button>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const bundleItems = document.querySelectorAll(".bundle-item");
  const cartButton = document.getElementById("add-bundle-to-cart");
  let selectedVariants = [];

  /* === Confetti rain from top of screen === */
  function spawnConfettiBurst(n = 18) {
    const colors = ['#FFB802', '#FF4D6D', '#4DD4FF', '#7AE582', '#FFD166', '#A78BFA'];
    for (let i = 0; i < n; i++) {
      const bit = document.createElement('span');
      bit.className = 'confetti';
      const hue = colors[i % colors.length];
      const left = 50 + (Math.random() * 20 - 10);
      const x = `calc(${left}vw)`;
      const drift = (Math.random() * 40 - 20) + 'vw';
      const dur = (1.1 + Math.random() * 0.7).toFixed(2) + 's';
      bit.style.left = x;
      bit.style.background = hue;
      bit.style.setProperty('--x', '0');
      bit.style.setProperty('--xEnd', drift);
      bit.style.setProperty('--t', dur);
      document.body.appendChild(bit);
      setTimeout(() => bit.remove(), 2200);
    }
  }

  /* === New: party popper around the toast (streamers + emojis + ring) === */
  function spawnPartyPopperAtToast(toast, pieces = 26, emojis = 14) {
    const rect = toast.getBoundingClientRect();
    const cx = rect.left + rect.width / 2;
    const cy = rect.top + 10; // near top edge of toast

    // expanding ring
    const ring = document.createElement('div');
    ring.className = 'popper-ring';
    ring.style.left = cx + 'px';
    ring.style.top  = cy + 'px';
    document.body.appendChild(ring);
    setTimeout(() => ring.remove(), 1100);

    // streamer pieces
    const colors = ['#FF3366', '#FFD166', '#06D6A0', '#118AB2', '#8338EC', '#FB5607'];
    for (let i = 0; i < pieces; i++) {
      const p = document.createElement('div');
      p.className = 'popper-piece';
      p.style.left = cx + 'px';
      p.style.top  = cy + 'px';
      p.style.background = colors[i % colors.length];

      // random vector (circle burst)
      const angle = (Math.random() * Math.PI * 2);
      const dist  = 70 + Math.random() * 90; // px
      const dx = Math.cos(angle) * dist + 'px';
      const dy = Math.sin(angle) * dist + 'px';
      const rot = (Math.random()*260 - 130) + 'deg';
      const dur = (750 + Math.random()*450) + 'ms';
      p.style.setProperty('--dx', dx);
      p.style.setProperty('--dy', dy);
      p.style.setProperty('--rot', rot);
      p.style.setProperty('--dur', dur);

      document.body.appendChild(p);
      setTimeout(() => p.remove(), 1400);
    }

    // emoji floaters
    const ems = ['🎉','🎊','✨','💥','🥳'];
    for (let i = 0; i < emojis; i++) {
      const e = document.createElement('span');
      e.className = 'emoji-pop';
      e.textContent = ems[i % ems.length];
      e.style.left = cx + 'px';
      e.style.top  = cy + 'px';
      const angle = (Math.random() * Math.PI * 2);
      const dist = 40 + Math.random()*80;
      const edx = Math.cos(angle) * dist + 'px';
      const edy = Math.sin(angle) * dist + 'px';
      const fz  = (16 + Math.random()*12) + 'px';
      const edur= (1100 + Math.random()*800) + 'ms';
      e.style.setProperty('--edx', edx);
      e.style.setProperty('--edy', edy);
      e.style.setProperty('--fz', fz);
      e.style.setProperty('--edur', edur);
      document.body.appendChild(e);
      setTimeout(() => e.remove(), 2000);
    }
  }

  /* --- Hurry toast + party popper + confetti + reload --- */
  function showHurryToastAndReload(message = 'Hurry! Bundle added — checkout before it sells out.', reloadDelay = 2100) {
    const toast = document.createElement('div');
    toast.className = 'hurry-toast';
    toast.setAttribute('role','status');
    toast.setAttribute('aria-live','polite');
    toast.innerHTML = `
      <div class="hurry-inner">
        <span class="hurry-icon">🔥</span>
        <span class="hurry-text">${message}</span>
      </div>
      <div class="hurry-progress"><i></i></div>
    `;
    document.body.appendChild(toast);

    // animate in
    requestAnimationFrame(() => toast.classList.add('show'));

    // global rain + local party popper around the toast
    spawnConfettiBurst(24);
    setTimeout(() => spawnPartyPopperAtToast(toast, 30, 16), 120); // tiny delay so position is stable

    // animate out + reload
    setTimeout(() => {
      toast.classList.remove('show');
      setTimeout(() => { toast.remove(); window.location.reload(); }, 280);
    }, reloadDelay);
  }

  function fetchVariants(productHandle, index) {
    fetch(`/products/${productHandle}.js`)
      .then(r => r.ok ? r.json() : Promise.reject(r.status))
      .then(data => {
        const variantContainer = document.getElementById(`variant-options-${index}`);
        const bundleItem = document.querySelector(`.bundle-item[data-product-handle="${productHandle}"]`);
        const firstMediaImage = data.images?.[0] || null;
        let firstAvailableSwatch = null;

        data.variants.forEach((variant) => {
          const swatch = document.createElement("button");
          swatch.classList.add("swatch");

          let imageName = variant.title.replace(/^#/, '').toLowerCase().replace(/\s+/g, '-');
          const swatchImage = `https://charmacyworld.com/cdn/shop/files/${imageName}_50x50.png`;
          swatch.style.backgroundImage = `url('${swatchImage}')`;
          swatch.style.backgroundSize = "cover";
          swatch.style.backgroundPosition = "center";
          swatch.style.width = "35px";
          swatch.style.height = "35px";
          swatch.title = variant.title;

          swatch.dataset.variantId = variant.id;
          swatch.dataset.price = (variant.price / 100);

          if (!variant.available) {
            swatch.classList.add("oos");
            swatch.setAttribute("aria-disabled", "true");
            swatch.title = `${variant.title} — Out of stock`;
          } else if (!firstAvailableSwatch) {
            firstAvailableSwatch = swatch;
          }

          swatch.addEventListener("click", function (e) {
            if (swatch.classList.contains("oos")) { e.preventDefault(); e.stopPropagation(); return; }
            document.querySelectorAll(`#variant-options-${index} .swatch`).forEach(s => s.classList.remove("active"));
            swatch.classList.add("active");

            selectedVariants[index - 1] = { id: variant.id, price: variant.price / 100 };

            const shadeNameEl = bundleItem.querySelector('.selected-shade-name');
            if (shadeNameEl) shadeNameEl.innerText = `- ${variant.title}`;

            const vfImg = bundleItem.querySelector('.vf-img');
            const vfImgUrl = variant.featured_image?.src
              ? `${variant.featured_image.src}&width=150`
              : firstMediaImage ? `${firstMediaImage}&width=150` : '';
            if (vfImg && vfImgUrl) {
              vfImg.style.backgroundImage = `url(${vfImgUrl})`;
              vfImg.style.backgroundSize = "cover";
              vfImg.style.backgroundPosition = "center";
              vfImg.style.width = "80px";
              vfImg.style.height = "80px";
              vfImg.dataset.shadeName = variant.title;
              vfImg.setAttribute("title", variant.title);
            }
          });

          variantContainer.appendChild(swatch);
        });

        if (firstAvailableSwatch) firstAvailableSwatch.click();
        else {
          const shadeNameEl = bundleItem.querySelector('.selected-shade-name');
          if (shadeNameEl) shadeNameEl.innerText = '— All variants out of stock';
        }
      })
      .catch(err => console.error('Variant load error for', productHandle, err));
  }

  // Init
  bundleItems.forEach((item, index) => {
    const handle = item.getAttribute("data-product-handle");
    fetchVariants(handle, index + 1);
  });

 cartButton.addEventListener("click", async () => {
  // Block if any bundle item is fully OOS
  const anyAllOOS = Array.from(document.querySelectorAll(".bundle-item")).some(item => {
    const swatches = item.querySelectorAll(".swatch");
    return swatches.length > 0 && Array.from(swatches).every(s => s.classList.contains("oos"));
  });
  if (anyAllOOS) { alert("One or more products in this bundle are out of stock."); return; }

  // Prepare items to add to the cart
  const itemsToAdd = selectedVariants
    .filter(v => v && v.id) // Only include selected variants
    .map((variant, i) => {
      const productHandle = document.querySelectorAll(".bundle-item")[i].getAttribute("data-product-handle");
      const shadeName = document.querySelectorAll(".vf-img")[i].dataset.shadeName || '';
      return { handle: productHandle, variant_id: variant.id, shade: shadeName, price: variant.price };
    });

  // Check if all products in the bundle have variants selected
  if (itemsToAdd.length !== bundleItems.length) {
    alert("Please select a variant for all products in the bundle.");
    return;
  }

  // Loop through each item and add them individually to the cart
  for (let item of itemsToAdd) {
    const res = await fetch(`/products/${item.handle}.js`);
    const product = await res.json();
    const variant = product.variants.find(v => v.id == item.variant_id);
    const sku = variant.sku || 'N/A';
    const price = (variant.price / 100).toFixed(0);  // Price in INR, format to integer
    const quantity = 1;

    const properties = {
      [`_bundle_product${itemsToAdd.indexOf(item) + 1}`]: `${sku}/${price}/${quantity}`,
      "Bundle ID": `BUNDLE-${Date.now()}`,
      "Product Count": 1 // Single product for each variant
    };

    const variantId = variant.id;
    if (!variantId) { alert("Variant not found."); return; }

    // Add the product to the cart as an individual item
    const response = await fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: quantity, properties })
    });

    if (!response.ok) {
      alert("Failed to add product to cart");
      return;
    }
  }

  // 🥳 Party popper hurry message + confetti + auto-reload
  showHurryToastAndReload();
});

});
</script>
