<!-- Sticky Top Marquee (place below your header in theme.liquid) -->
<div class="promo-marquee" role="region" aria-label="Promotional offer">
  <a class="promo-marquee__link" href="{{ routes.collections_url }}/b1g1" aria-label="Shop Buy 1 Get 1">
    <div class="promo-marquee__track">
      <div class="promo-marquee__row">
        <span class="promo-marquee__item">Buy 1 Get 1</span>
        <span class="promo-marquee__sep">||</span>
        <span class="promo-marquee__item">Add 2 products and pay for 1 only . 🎉</span>
        <span class="promo-marquee__sep">||</span>
      </div>
      <!-- Duplicate for seamless loop -->
      <div class="promo-marquee__row" aria-hidden="true">
        <span class="promo-marquee__item">Buy 1 Get 1</span>
        <span class="promo-marquee__sep">||</span>
        <span class="promo-marquee__item">Add 2 products and pay for 1 only . 🎉</span>
        <span class="promo-marquee__sep">||</span>
      </div>
    </div>
  </a>
</div>

<style>
  .promo-marquee{
    {% comment %} position: sticky; top: 0; z-index: 50; {% endcomment %}
    width: 100%;
    background: #64112f;
    border-bottom: 1px solid #f2dada;
    color: #fff5f5;
    font: 600 14px/1 system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
    overflow: hidden; white-space: nowrap;
  }
  .promo-marquee__link{
    display:block; width:100%; height:100%;
    color: inherit; text-decoration: none; cursor: pointer;
  }

  .promo-marquee__track{
    display: flex; gap: 0; will-change: transform;
  }
  .promo-marquee__row{
    display: inline-flex; align-items: center; gap: 10px;
    padding: 12px 16px;
    animation: promo-scroll 12s linear infinite;
  }
  .promo-marquee__row + .promo-marquee__row{ margin-left: 40px; }

  .promo-marquee__item{ letter-spacing: .2px }
  .promo-marquee__sep{ opacity: .6; padding: 0 6px }

  /* Pause on hover (desktop) */
  .promo-marquee:hover .promo-marquee__row{ animation-play-state: paused; }

  /* Reduced motion */
 

  @keyframes promo-scroll{
    from { transform: translateX(0) }
    to   { transform: translateX(-100%) }
  }

  /* Mobile tweak */
  @media (max-width: 480px){
    .promo-marquee{ font-size: 15px }
    .promo-marquee__row{ padding: 12px 12px ;color:white;}
  }
</style>
