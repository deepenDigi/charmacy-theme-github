{% schema %}
  {
    "name": "Multi variant section",
    "settings": [
      {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "PADDING TOP",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "PADDING BOTTOM",
      "default": 36
    }
    ],
    "presets": [
      {
        "name": "Multi variant section"
      }
    ]
  }
{% endschema %}