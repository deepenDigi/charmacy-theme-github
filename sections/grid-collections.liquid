{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<style>
    .main-cl-grid {
      display: grid;
      /* grid-template-columns: repeat(3, 1fr);
      grid-template-rows: repeat(2, 1fr); */
      grid-template-columns: repeat(7, 1fr);
      grid-template-rows: repeat(4, 1fr);
      grid-column-gap: 10px;
      grid-row-gap: 10px;
    }
  
  .cl-grid-item-1 { 
    /* grid-area: 1 / 1 / 2 / 3;  */
    grid-area: 1 / 1 / 3 / 5;
  }
  .cl-grid-item-2 { 
    /* grid-area: 1 / 3 / 2 / 4;  */
    grid-area: 1 / 5 / 3 / 8; 
  }
  .cl-grid-item-3 { 
    /* grid-area: 2 / 1 / 3 / 2;  */
    grid-area: 3 / 1 / 5 / 4;
  }
  .cl-grid-item-4 { 
    /* grid-area: 2 / 2 / 3 / 4;  */
    grid-area: 3 / 4 / 5 / 8;
  }
  .cl-grid-item img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
}

.cl-grid-item {
    width: 100%;
    height: 100%;
      max-height: 350px;
       border-radius: 5px;
    overflow: hidden;
      border: 2px solid #ffffff;
}
  .cl-grid-item a {
    width: 100%;
    height: 100%;
    display: block;
 
}
.grid-collection-wrapper{
  /* margin-top: 60px; */
  
  /* background: radial-gradient(circle, rgba(206, 62, 88, 1) 0%, rgba(100, 17, 47, 1) 100%); */
  /* background: radial-gradient(circle, rgb(255 130 153) 0%, rgb(255 255 255) 100%); */
  background: #f3f3f3;
  border-top: 1px solid #9d0d42;
  border-bottom: 1px solid #9d0d42;
}
  .grid-collection-wrapper .section-header__title {
    color: #000;
}
  .cl-grid-item img.bl-480px {
    display: none;
}

 @media(max-width: 768px){
   .main-cl-grid {
     grid-template-columns: repeat(8, 1fr);
      grid-template-rows: repeat(6, 1fr);
     gap: 0px;
   }
   .cl-grid-item-1{
       grid-area: 1 / 1 / 3 / 9;
   }
   .cl-grid-item-2{
       grid-area: 3 / 1 / 5 / 5;
   }
   .cl-grid-item-3{
       grid-area: 3 / 5 / 5 / 9;
   }
   .cl-grid-item-4{
       grid-area: 5 / 1 / 7 / 9;
   }
   .grid-collection-wrapper{
    
     
     /* background: radial-gradient(circle, rgb(251 132 154) 70%, rgb(255 255 255) 100%); */
   }
   .grid-collection-wrapper .section-header__title{
         font-size: 25px;
      letter-spacing: -1px;

   }
 } 
  @media(max-width: 480px){
     .cl-grid-item img.bl-480px {
        display: block;
    }
     .cl-grid-item img.ab-480px {
        display: none;
    }
    .grid-collection-wrapper{
       
    }
  }
  </style>
  
  <div class="grid-collection-wrapper section-{{ section.id }}-padding">
    <div class="page-width">
        <div class="section-header">
            <h2 class="section-header__title">All You Need to Slay the Day!</h2>
        </div>
        <div class="main-cl-grid">
            <div class="cl-grid-item cl-grid-item-1">
                <a href="/products/cmc-stunning-longstay-liquid-lip"> 
                    <img src="https://cdn.shopify.com/s/files/1/0558/4584/7231/files/Charmasy_web_images.jpg?v=1741608843" alt="Charmacy beauty products collection with trendy makeup essentials online">
                </a>
            </div>
            <div class="cl-grid-item cl-grid-item-2">
                <a href="/products/cmc-concealer"> 
                    <img class="ab-480px" src="https://cdn.shopify.com/s/files/1/0558/4584/7231/files/Artboard_2_1.png?v=1741784729" alt="">
                    <img class="bl-480px" src="https://cdn.shopify.com/s/files/1/0558/4584/7231/files/Artboard_4_dd5e30d6-d8a8-4e47-ae46-f570bc1216bb.png?v=1741845098" alt="Charmacy luxury makeup products Concealer  for glowing skin and stylish beauty looks">
                </a>
            </div>
            <div class="cl-grid-item cl-grid-item-3">
                <a href="/products/eyes-looks-cmc-duo-zodiac-eyeshadow-stick"> 
                    <img class="ab-480px" src="https://cdn.shopify.com/s/files/1/0558/4584/7231/files/Artboard_1_887a4118-8f54-43e3-bdab-d674072b5211.png?v=1741846295" alt="">
                    <img class="bl-480px" src="https://cdn.shopify.com/s/files/1/0558/4584/7231/files/Artboard_3_065aaed4-d4dc-46b9-9a1f-8e8f9cd2f982.png?v=1741845098" alt="Luxury cosmetic products collection by Charmacy for flawless eye makeup looks">
                </a>
            </div>
            <div class="cl-grid-item cl-grid-item-4">
                <a href="/products/cmc-cheek-enhancer"> 
                    {% comment %} <img src="https://cdn.shopify.com/s/files/1/0558/4584/7231/files/Charmasy_web_2.jpg?v=1741608843" alt=""> {% endcomment %}
                    <img src="https://cdn.shopify.com/s/files/1/0558/4584/7231/files/fd.png?v=1767951834" alt="">
                </a>
            </div>
        </div>
    </div>
  </div>
{% schema %}
  {
    "name": "Grid Collections",
    "settings": [
      {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "PADDING TOP",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "PADDING BOTTOM",
      "default": 36
    }
    ],
    "presets": [
      {
        "name": "Grid Collections"
      }
    ]
  }
{% endschema %}